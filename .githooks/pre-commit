#!/bin/sh
#
# betterleaks pre-commit hook
# Scans staged changes for secrets before committing.
# Enabled via: git config core.hooksPath .githooks
#
# betterleaks is managed by mise (see app/mise/config.toml).

set -e

if command -v betterleaks >/dev/null 2>&1; then
	betterleaks git --pre-commit --staged --redact
elif command -v mise >/dev/null 2>&1; then
	mise exec betterleaks -- betterleaks git --pre-commit --staged --redact
else
	echo "betterleaks not found. install it with: mise install betterleaks" >&2
	exit 1
fi
